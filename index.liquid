---
layout: layout.liquid
title: Home
---

<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;500;600;700&family=Orbitron:wght@400;500;600;700;900&display=swap" rel="stylesheet">

<style>
/* ═══════════════════════════════════════════════════════════════════════
   NERV · MAGI SYSTEM — ONE-PAGE PORTFOLIO
   3-colour palette: --void (near-black) · --orange · --maroon
═══════════════════════════════════════════════════════════════════════ */
:root {
  /* ── Backgrounds */
  --void:      #050402;
  --panel:     rgba(16,10,4,.85);
  --panel-lo:  rgba(12,8,4,.72);

  /* ── 3-colour system */
  --orange:    #e85f00;
  --orange-hi: #ff7a20;
  --orange-lo: #b84a00;
  --maroon:    #6b0e00;
  --maroon-hi: #8b1500;

  /* ── Borders (derived) */
  --border:    rgba(180,60,0,.22);
  --border-hi: rgba(230,100,0,.40);
  --border-lo: rgba(100,14,0,.16);

  /* ── Text (warm neutrals, no blues) */
  --text:      #f0c898;
  --text-2:    #c8956a;
  --text-3:    #8a5a38;
  --text-dim:  #4a3020;
  --white:     #ffe8c8;

  /* ── Glow */
  --glow:      rgba(230,95,0,.28);
  --glow-hi:   rgba(255,122,32,.45);

  /* ── Grid overlay */
  --grid-c:    rgba(180,60,0,.05);

  /* ── Fonts */
  --font-orb:  'Orbitron', sans-serif;
  --font-raj:  'Rajdhani', sans-serif;
  --font-mono: 'Share Tech Mono', monospace;

  --r:   3px;
  --ease: cubic-bezier(.22,1,.36,1);
}

/* ── Reset */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

body {
  font-family: var(--font-raj);
  background: var(--void);
  color: var(--text);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
  padding-bottom: 26px; /* ticker */
}

/* ── MAGI grid */
body::before {
  content: '';
  position: fixed; inset: 0;
  pointer-events: none; z-index: 0;
  background-image:
    linear-gradient(var(--grid-c) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-c) 1px, transparent 1px);
  background-size: 44px 44px;
}

/* ── CRT scanlines */
body::after {
  content: '';
  position: fixed; inset: 0;
  pointer-events: none; z-index: 0;
  background: repeating-linear-gradient(
    0deg,
    rgba(0,0,0,.12) 0px, rgba(0,0,0,.12) 1px,
    transparent 1px, transparent 4px
  );
}

/* ── Ambient glow */
.amb {
  position: fixed; inset: 0;
  pointer-events: none; z-index: 0;
  background:
    radial-gradient(ellipse 900px 500px at 10% 15%, rgba(107,14,0,.10) 0%, transparent 70%),
    radial-gradient(ellipse 700px 500px at 90% 80%, rgba(180,50,0,.08) 0%, transparent 70%),
    radial-gradient(ellipse 500px 300px at 50% 50%, rgba(50,8,0,.06) 0%, transparent 70%);
}

.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 2rem;
  position: relative;
  z-index: 2;
}

/* ════════════════════════════════════════════════
   NAV
════════════════════════════════════════════════ */
#site-nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 200;
  border-bottom: 1px solid transparent;
  transition: background .4s var(--ease), border-color .4s var(--ease), backdrop-filter .4s var(--ease);
}
#site-nav.scrolled {
  background: rgba(5,4,2,.95);
  backdrop-filter: blur(20px) saturate(150%);
  -webkit-backdrop-filter: blur(20px) saturate(150%);
  border-color: var(--border-lo);
}

.nav-inner {
  max-width: 1100px;
  margin: 0 auto;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 2rem;
  gap: 2rem;
}

.nav-logo {
  font-family: var(--font-mono);
  font-size: .8rem;
  color: var(--orange);
  text-decoration: none;
  letter-spacing: .18em;
  text-shadow: 0 0 14px var(--glow);
  display: flex;
  align-items: center;
  gap: .5rem;
  flex-shrink: 0;
}
.nav-logo-dot {
  width: 6px; height: 6px;
  background: var(--orange);
  border-radius: 1px;
  box-shadow: 0 0 8px var(--glow);
  animation: blink 1.4s step-start infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

.nav-links { display: flex; list-style: none; gap: .1rem; }
.nav-link {
  font-family: var(--font-mono);
  font-size: .65rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--text-3);
  padding: .45rem .85rem;
  border-radius: var(--r);
  transition: color .2s, background .2s;
  position: relative;
}
.nav-link:hover { color: var(--orange); }
.nav-link.active {
  color: var(--orange);
}
.nav-link.active::after {
  content: '';
  position: absolute;
  bottom: 4px; left: 50%;
  transform: translateX(-50%);
  width: 3px; height: 3px;
  background: var(--orange);
  border-radius: 50%;
  box-shadow: 0 0 6px var(--glow);
}

.nav-status {
  font-family: var(--font-mono);
  font-size: .58rem;
  color: var(--maroon-hi);
  letter-spacing: .18em;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: .5rem;
  flex-shrink: 0;
}
.nav-status-dot {
  width: 5px; height: 5px;
  background: var(--orange);
  border-radius: 50%;
  box-shadow: 0 0 6px var(--glow);
  animation: blink 2.2s ease-in-out infinite;
}

/* mobile */
.nav-mobile-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none; border: none;
  padding: 4px; cursor: pointer;
}
.nav-mobile-toggle span {
  display: block; width: 22px; height: 2px;
  background: var(--text-2); border-radius: 2px;
  transition: transform .25s, opacity .2s;
  transform-origin: center;
}
.nav-mobile-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-mobile-toggle.open span:nth-child(2) { opacity: 0; }
.nav-mobile-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

.nav-mobile-menu {
  display: none;
  background: rgba(5,4,2,.98);
  border-bottom: 1px solid var(--border-lo);
  overflow: hidden;
  max-height: 0;
  transition: max-height .35s var(--ease);
}
.nav-mobile-menu.open { max-height: 300px; }
.nav-mobile-menu ul { list-style: none; padding: .75rem 1.5rem 1.25rem; }
.nav-mobile-menu .nav-link { display: block; padding: .6rem .5rem; }

/* ════════════════════════════════════════════════
   SECTION COMMON
════════════════════════════════════════════════ */
.section {
  position: relative; z-index: 2;
  padding: 6rem 0;
}
.section--alt {
  background: var(--panel-lo);
  border-top: 1px solid var(--border-lo);
  border-bottom: 1px solid var(--border-lo);
}

.section-eyebrow {
  font-family: var(--font-mono);
  font-size: .65rem;
  letter-spacing: .38em;
  text-transform: uppercase;
  color: var(--maroon-hi);
  display: flex;
  align-items: center;
  gap: .65rem;
  margin-bottom: .6rem;
}
.section-eyebrow::before {
  content: '';
  display: inline-block;
  width: 20px; height: 1px;
  background: var(--maroon-hi);
  flex-shrink: 0;
}

.section-title {
  font-family: var(--font-raj);
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 700;
  color: var(--white);
  text-transform: uppercase;
  letter-spacing: .1em;
  text-shadow: 0 0 30px var(--glow);
  position: relative;
  display: inline-block;
  margin-bottom: 2.5rem;
}
.section-title::after {
  content: '';
  position: absolute;
  bottom: -8px; left: 0; width: 100%; height: 1px;
  background: linear-gradient(90deg, var(--orange), var(--maroon), transparent);
  box-shadow: 0 0 8px var(--glow);
}

/* ════════════════════════════════════════════════
   BOOT SCREEN
════════════════════════════════════════════════ */
#boot-screen {
  position: fixed; inset: 0;
  z-index: 999;
  background: var(--void);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 1.5rem;
  animation: boot-fade 2.8s var(--ease) forwards;
}
@keyframes boot-fade {
  0%   { opacity:1; visibility:visible; }
  75%  { opacity:1; }
  100% { opacity:0; visibility:hidden; pointer-events:none; }
}
.boot-logo {
  font-family: var(--font-orb);
  font-size: clamp(1.1rem, 4vw, 1.9rem);
  color: var(--orange);
  letter-spacing: .3em;
  text-shadow: 0 0 30px var(--glow-hi);
  animation: boot-flicker .08s step-start 4 .3s;
}
@keyframes boot-flicker { 0%,100%{opacity:1} 50%{opacity:0} }
.boot-lines {
  font-family: var(--font-mono);
  font-size: .68rem;
  color: var(--maroon-hi);
  letter-spacing: .12em;
  text-align: center;
  display: flex; flex-direction: column; gap: .4rem;
}
.boot-line { opacity:0; animation: boot-line-in .3s forwards; }
.boot-line:nth-child(1) { animation-delay:.3s; }
.boot-line:nth-child(2) { animation-delay:.7s; }
.boot-line:nth-child(3) { animation-delay:1.1s; }
.boot-line:nth-child(4) { animation-delay:1.5s; color:var(--orange); }
@keyframes boot-line-in { from{opacity:0;transform:translateX(-10px)} to{opacity:1;transform:none} }
.boot-bar-wrap {
  width: min(320px,70vw); height: 3px;
  background: var(--border-lo); border-radius: 2px;
  overflow: hidden; margin-top: .5rem;
}
.boot-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--maroon), var(--orange));
  box-shadow: 0 0 10px var(--glow);
  width: 0;
  animation: boot-bar-fill 1.8s .4s forwards;
}
@keyframes boot-bar-fill { to { width:100%; } }

/* ════════════════════════════════════════════════
   HERO
   FIX: removed overflow:hidden (caused clipping),
        removed hero-top-bar, removed clip-path from glitch
════════════════════════════════════════════════ */
#hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 7rem 0 5rem;
  border-bottom: 1px solid var(--border);
  /* NO overflow:hidden — was causing name clip bug */
}

.hero-dataflow {
  position: absolute; inset: 0;
  pointer-events: none; z-index: 1;
  overflow: hidden;
  opacity: .035;
}
.hero-dataflow-inner {
  position: absolute;
  top: -40%; left: -20%;
  width: 140%; height: 180%;
  display: flex; flex-wrap: wrap; gap: 14px;
  transform: rotate(-18deg);
  animation: data-drift 16s linear infinite;
}
@keyframes data-drift { to { transform: rotate(-18deg) translateY(-80px); } }
.data-node {
  font-family: var(--font-mono);
  font-size: .62rem;
  color: var(--orange);
  letter-spacing: .1em;
  white-space: nowrap;
}

.hero-system-id {
  font-family: var(--font-mono);
  font-size: .65rem;
  color: var(--text-3);
  letter-spacing: .3em;
  text-transform: uppercase;
  margin-bottom: 1.25rem;
  display: flex; align-items: center; gap: .65rem;
  position: relative; z-index: 2;
}
.hero-system-id::before {
  content: '';
  display: inline-block; width: 7px; height: 7px;
  background: var(--orange); border-radius: 1px;
  box-shadow: 0 0 10px var(--glow);
  animation: blink 1.4s step-start infinite;
}

/* FIX: glitch uses only skew+text-shadow — no clip-path to get stuck */
.hero-name {
  font-family: var(--font-orb);
  font-size: clamp(2.4rem, 8vw, 6rem);
  font-weight: 900;
  color: var(--white);
  text-transform: uppercase;
  letter-spacing: .04em;
  line-height: 1;
  text-shadow: 0 0 60px var(--glow), 0 0 120px rgba(180,40,0,.10);
  margin-bottom: .7rem;
  position: relative; z-index: 2;
  animation: hero-glitch 8s ease-in-out infinite;
}
@keyframes hero-glitch {
  0%,88%,100% {
    text-shadow: 0 0 60px var(--glow), 0 0 120px rgba(180,40,0,.10);
    transform: none;
  }
  90% { text-shadow: -3px 0 var(--orange-hi), 3px 0 var(--maroon-hi); transform: skewX(-1.5deg); }
  91% { text-shadow:  3px 0 var(--orange),    -3px 0 var(--maroon);   transform: skewX(.8deg); }
  92% { text-shadow:  0 0 60px var(--glow);   transform: none; }
}

.hero-role {
  font-family: var(--font-mono);
  font-size: clamp(.72rem, 2vw, .92rem);
  color: var(--orange);
  letter-spacing: .25em;
  text-transform: uppercase;
  text-shadow: 0 0 12px var(--glow);
  margin-bottom: 1.75rem;
  position: relative; z-index: 2;
}

.hero-bio {
  font-size: 1rem;
  font-weight: 400;
  color: var(--text-2);
  line-height: 1.82;
  max-width: 580px;
  margin-bottom: 2.25rem;
  position: relative; z-index: 2;
}

.hero-cta {
  display: flex; gap: .75rem; flex-wrap: wrap;
  margin-bottom: 3rem;
  position: relative; z-index: 2;
}

/* ── Buttons */
.btn {
  font-family: var(--font-mono);
  font-size: .68rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  padding: .75rem 1.85rem;
  border-radius: var(--r);
  text-decoration: none;
  display: inline-flex; align-items: center; gap: .5rem;
  transition: all .3s var(--ease);
  position: relative; overflow: hidden;
  cursor: pointer; border: none;
  white-space: nowrap;
}
.btn::before {
  content: '';
  position: absolute; inset: 0;
  background: var(--orange);
  transform: scaleX(0); transform-origin: left;
  transition: transform .3s var(--ease);
}
.btn span, .btn svg { position: relative; z-index: 1; }

.btn--primary {
  border: 1px solid var(--orange);
  color: var(--orange);
  background: transparent;
}
.btn--primary:hover {
  color: var(--void);
  box-shadow: 0 0 24px var(--glow);
}
.btn--primary:hover::before { transform: scaleX(1); }

.btn--ghost {
  border: 1px solid var(--border);
  color: var(--text-3);
  background: transparent;
}
.btn--ghost::before { background: rgba(180,60,0,.14); }
.btn--ghost:hover { color: var(--text-2); border-color: var(--border-hi); }
.btn--ghost:hover::before { transform: scaleX(1); }

/* ── Hero stats */
.hero-stats {
  display: flex; gap: 2.5rem; flex-wrap: wrap;
  position: relative; z-index: 2;
}
.hero-stat {
  border-left: 2px solid var(--maroon);
  padding-left: .85rem;
  display: flex; flex-direction: column; gap: .2rem;
}
.hero-stat-val {
  font-family: var(--font-orb);
  font-size: 1.5rem; font-weight: 700;
  color: var(--orange);
  text-shadow: 0 0 12px var(--glow);
  line-height: 1;
}
.hero-stat-lbl {
  font-family: var(--font-mono);
  font-size: .56rem; color: var(--text-3);
  letter-spacing: .2em; text-transform: uppercase;
}

/* ════════════════════════════════════════════════
   SECTION DIVIDERS
════════════════════════════════════════════════ */
.nerv-divider {
  position: relative; z-index: 2;
  height: 2px;
  background: linear-gradient(90deg, transparent 0%, var(--maroon) 20%, var(--orange) 50%, var(--maroon) 80%, transparent 100%);
  box-shadow: 0 0 10px var(--glow);
  opacity: .32;
}
.nerv-divider-label {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  background: var(--void);
  padding: 0 1rem;
  font-family: var(--font-mono);
  font-size: .52rem; color: var(--maroon-hi);
  letter-spacing: .28em; white-space: nowrap;
}

/* ════════════════════════════════════════════════
   ABOUT
════════════════════════════════════════════════ */
.about-grid {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 3rem; align-items: start;
}
.about-avatar-wrap {
  display: flex; flex-direction: column;
  align-items: center; gap: .85rem;
}
.about-avatar {
  width: 108px; height: 108px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--maroon) 0%, var(--orange-lo) 100%);
  border: 1px solid rgba(230,95,0,.30);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-orb);
  font-size: 1.75rem; font-weight: 700;
  color: var(--white);
  box-shadow: 0 0 40px rgba(107,14,0,.35), inset 0 1px 0 rgba(255,255,255,.08);
  position: relative; flex-shrink: 0;
}
.about-avatar::before {
  content: ''; position: absolute; inset: -9px;
  border-radius: 50%; border: 1px solid rgba(230,95,0,.22);
  animation: ring-pulse 3s ease-in-out infinite;
}
.about-avatar::after {
  content: ''; position: absolute; inset: -18px;
  border-radius: 50%; border: 1px solid rgba(107,14,0,.15);
  animation: ring-pulse 3s ease-in-out infinite .9s;
}
@keyframes ring-pulse { 0%,100%{transform:scale(1);opacity:.8} 50%{transform:scale(1.08);opacity:.15} }

.about-unit-label {
  font-family: var(--font-mono);
  font-size: .56rem; color: var(--maroon-hi); letter-spacing: .22em;
}
.about-name {
  font-family: var(--font-raj);
  font-size: clamp(1.5rem, 2.8vw, 2.1rem);
  font-weight: 700; color: var(--white);
  text-transform: uppercase; letter-spacing: .08em;
  margin-bottom: .35rem;
}
.about-subtitle {
  font-family: var(--font-mono);
  font-size: .7rem; color: var(--orange);
  letter-spacing: .1em; margin-bottom: 1.4rem; display: block;
}
.about-text { font-size: .97rem; color: var(--text-2); line-height: 1.82; margin-bottom: .9rem; }
.about-cta { display: flex; gap: .7rem; flex-wrap: wrap; margin-top: 1.65rem; }

/* ════════════════════════════════════════════════
   SKILLS  (merged: domain cards + chip blocks in one section)
════════════════════════════════════════════════ */
.skills-section-header {
  margin-top: 4rem;
  margin-bottom: 2rem;
  padding-top: 2.5rem;
  border-top: 1px solid var(--border-lo);
}

/* Domain cards */
.domain-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1.25rem;
  margin-bottom: 2rem;
}
.domain-card {
  background: var(--panel);
  border: 1px solid var(--border-lo);
  padding: 1.5rem; border-radius: var(--r);
  position: relative; overflow: hidden;
  transition: border-color .3s var(--ease), transform .3s var(--ease), box-shadow .3s var(--ease);
  backdrop-filter: blur(8px);
}
/* corner brackets */
.domain-card::before {
  content: ''; position: absolute; top:-1px; left:-1px;
  width:14px; height:14px;
  border-top:1px solid var(--orange); border-left:1px solid var(--orange);
}
.domain-card::after {
  content: ''; position: absolute; bottom:-1px; right:-1px;
  width:14px; height:14px;
  border-bottom:1px solid var(--maroon); border-right:1px solid var(--maroon);
}
.domain-card-bar {
  position: absolute; top:0; left:0; right:0; height:2px;
  background: linear-gradient(90deg, transparent, var(--orange), transparent);
  opacity:0; transition: opacity .3s;
}
.domain-card:hover .domain-card-bar { opacity:1; }
.domain-card:hover {
  border-color: var(--border-hi);
  transform: translateY(-3px);
  box-shadow: 0 10px 36px rgba(0,0,0,.45), 0 0 16px rgba(180,40,0,.07);
}

.domain-badge {
  font-family: var(--font-mono); font-size: .6rem;
  padding: .18rem .72rem; border-radius: var(--r);
  text-transform: uppercase; letter-spacing: .12em;
  margin-bottom: .9rem; display: inline-block;
  /* All use orange/maroon, no blues */
  background: rgba(180,60,0,.15);
  color: var(--orange);
  border: 1px solid rgba(180,60,0,.28);
}
.domain-title {
  font-family: var(--font-raj); font-size: .92rem;
  font-weight: 700; color: var(--text);
  text-transform: uppercase; letter-spacing: .06em; margin-bottom: .8rem;
}
.domain-list { list-style: none; }
.domain-list li {
  font-size: .87rem; color: var(--text-2);
  padding: .3rem 0 .3rem 1.2rem;
  border-bottom: 1px solid rgba(180,60,0,.06);
  position: relative; line-height: 1.5;
}
.domain-list li:last-child { border-bottom: none; }
.domain-list li::before { content:'›'; position:absolute; left:0; color:var(--orange); line-height:1.5; }

/* Chip rows (languages, tools) */
.skills-row {
  display: flex; align-items: center;
  gap: .75rem; flex-wrap: wrap;
  margin-bottom: 1.5rem;
}
.skills-row-label {
  font-family: var(--font-mono); font-size: .6rem;
  color: var(--orange); letter-spacing: .28em;
  text-transform: uppercase; flex-shrink: 0;
  white-space: nowrap;
}
.chip-row { display: flex; flex-wrap: wrap; gap: .38rem; }
.chip {
  font-family: var(--font-mono); font-size: .7rem;
  background: rgba(180,60,0,.1);
  border: 1px solid rgba(180,60,0,.20);
  color: var(--text-2);
  padding: .26rem .82rem; border-radius: var(--r);
  letter-spacing: .05em;
  transition: background .22s, border-color .22s, color .22s, box-shadow .22s;
  cursor: default;
}
.chip:hover {
  background: rgba(230,95,0,.18); border-color: var(--orange);
  color: var(--text); box-shadow: 0 0 10px var(--glow);
}

/* ════════════════════════════════════════════════
   PROJECTS
════════════════════════════════════════════════ */
.filter-bar { display: flex; gap: .45rem; flex-wrap: wrap; margin-bottom: 2.25rem; }
.filter-btn {
  font-family: var(--font-mono); font-size: .65rem;
  letter-spacing: .12em; text-transform: uppercase;
  padding: .5rem 1.05rem;
  border: 1px solid var(--border-lo);
  background: transparent; color: var(--text-3);
  border-radius: var(--r); cursor: pointer;
  transition: border-color .22s, color .22s, background .22s, box-shadow .22s;
}
.filter-btn:hover { border-color: var(--orange); color: var(--orange); background: rgba(230,95,0,.05); }
.filter-btn.active {
  background: var(--orange); border-color: var(--orange);
  color: var(--void); font-weight: 700;
  box-shadow: 0 0 14px var(--glow);
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px,1fr));
  gap: 1.2rem;
}
.project-card {
  background: var(--panel);
  border: 1px solid var(--border-lo); border-radius: var(--r);
  padding: 1.4rem;
  display: flex; flex-direction: column; gap: .65rem;
  position: relative; overflow: hidden;
  transition: border-color .3s var(--ease), transform .3s var(--ease), box-shadow .3s var(--ease);
  backdrop-filter: blur(8px);
  animation: card-in .4s var(--ease) both;
}
@keyframes card-in { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:none} }
.project-card::before {
  content:''; position:absolute; top:-1px; left:-1px;
  width:12px; height:12px;
  border-top:1px solid var(--orange); border-left:1px solid var(--orange);
}
.project-card::after {
  content:''; position:absolute; bottom:-1px; right:-1px;
  width:12px; height:12px;
  border-bottom:1px solid var(--maroon); border-right:1px solid var(--maroon);
}
.project-card-bar {
  position:absolute; top:0; left:0; right:0; height:2px;
  background:linear-gradient(90deg,transparent,var(--orange),transparent);
  opacity:0; transition:opacity .3s;
}
.project-card:hover .project-card-bar { opacity:1; }
.project-card:hover {
  border-color: var(--border-hi);
  transform: translateY(-4px);
  box-shadow: 0 14px 44px rgba(0,0,0,.5), 0 0 18px rgba(180,40,0,.07);
}

.project-card-top { display:flex; align-items:center; justify-content:space-between; }
/* All project badges in orange/maroon — no category-specific blues */
.project-badge {
  font-family: var(--font-mono); font-size: .6rem;
  padding: .17rem .7rem; border-radius: var(--r);
  letter-spacing: .1em; text-transform: uppercase;
  background: rgba(180,60,0,.14);
  color: var(--orange);
  border: 1px solid rgba(180,60,0,.26);
}
.project-year { font-family:var(--font-mono); font-size:.63rem; color:var(--text-3); }
.project-status-active {
  font-family:var(--font-mono); font-size:.58rem;
  background:rgba(230,95,0,.1); border:1px solid var(--orange);
  color:var(--orange); padding:.14rem .58rem; border-radius:var(--r);
  animation: pulse-border 2.2s ease-in-out infinite;
}
@keyframes pulse-border { 0%,100%{box-shadow:none} 50%{box-shadow:0 0 8px var(--glow)} }
.project-title {
  font-family:var(--font-raj); font-size:1.1rem; font-weight:600;
  color:var(--white); letter-spacing:.03em; transition:color .22s;
}
.project-card:hover .project-title { color:var(--orange-hi); }
.project-desc { font-size:.89rem; color:var(--text-2); line-height:1.72; flex-grow:1; }
.project-tags { display:flex; flex-wrap:wrap; gap:.32rem; }
.project-tag {
  font-family:var(--font-mono); font-size:.63rem;
  background:rgba(180,60,0,.09); border:1px solid rgba(180,60,0,.16);
  color:var(--text-3); padding:.16rem .58rem; border-radius:var(--r);
}
.project-links {
  display:flex; gap:1rem; padding-top:.5rem;
  border-top:1px solid var(--border-lo);
}
.project-link {
  font-family:var(--font-mono); font-size:.68rem;
  color:var(--orange); text-decoration:none;
  letter-spacing:.06em; display:flex; align-items:center; gap:.35rem;
  transition:color .2s, text-shadow .2s;
}
.project-link:hover { color:var(--orange-hi); text-shadow:0 0 8px var(--glow); }

/* ════════════════════════════════════════════════
   EXPERIENCE / TIMELINE
════════════════════════════════════════════════ */
.timeline { position:relative; padding-left:2rem; }
.timeline-item { position:relative; margin-bottom:2.25rem; display:flex; gap:1.4rem; }
.timeline-marker { position:absolute; left:-2rem; top:0; display:flex; flex-direction:column; align-items:center; }
.timeline-dot {
  width:10px; height:10px; background:var(--orange);
  border-radius:var(--r); box-shadow:0 0 10px var(--glow);
  flex-shrink:0; margin-top:5px; position:relative;
}
.timeline-dot::after {
  content:''; position:absolute; inset:-4px;
  border:1px solid rgba(230,95,0,.28); border-radius:var(--r);
  animation:dot-pulse 2.5s ease-in-out infinite;
}
@keyframes dot-pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0;transform:scale(1.7)} }
.timeline-item--education .timeline-dot { background:var(--maroon-hi); box-shadow:0 0 10px rgba(107,14,0,.5); }
.timeline-line {
  width:1px; flex-grow:1;
  background:linear-gradient(var(--border-lo), transparent);
  min-height:40px; margin-top:4px;
}
.timeline-body {
  flex-grow:1;
  background:var(--panel);
  border:1px solid var(--border-lo);
  padding:1.35rem 1.55rem; border-radius:var(--r);
  position:relative;
  transition:border-color .3s, box-shadow .3s;
  backdrop-filter:blur(6px);
}
.timeline-body::before {
  content:''; position:absolute; top:-1px; left:-1px;
  width:12px; height:12px;
  border-top:1px solid var(--orange); border-left:1px solid var(--orange);
}
.timeline-body::after {
  content:''; position:absolute; bottom:-1px; right:-1px;
  width:12px; height:12px;
  border-bottom:1px solid var(--maroon); border-right:1px solid var(--maroon);
}
.timeline-body:hover { border-color:var(--border-hi); box-shadow:0 0 20px rgba(180,40,0,.07); }
.timeline-header { display:flex; justify-content:space-between; align-items:flex-start; gap:1rem; flex-wrap:wrap; margin-bottom:.6rem; }
.timeline-role { font-family:var(--font-raj); font-size:1.05rem; font-weight:700; color:var(--white); text-transform:uppercase; letter-spacing:.05em; }
.timeline-company { font-family:var(--font-mono); font-size:.76rem; color:var(--orange); margin-top:.18rem; letter-spacing:.08em; }
.timeline-meta { text-align:right; flex-shrink:0; }
.timeline-dates { font-family:var(--font-mono); font-size:.66rem; color:var(--text-3); letter-spacing:.08em; display:block; }
.timeline-location { font-family:var(--font-mono); font-size:.63rem; color:var(--text-dim); display:block; margin-top:.12rem; }
.timeline-current { color:var(--orange); text-shadow:0 0 8px var(--glow); }
.timeline-desc { font-size:.9rem; color:var(--text-2); line-height:1.72; }
.timeline-tags { display:flex; flex-wrap:wrap; gap:.38rem; margin-top:.62rem; }
.timeline-tag {
  font-family:var(--font-mono); font-size:.63rem;
  background:rgba(180,60,0,.09); border:1px solid rgba(180,60,0,.17);
  color:var(--text-3); padding:.16rem .62rem; border-radius:var(--r);
}

/* ════════════════════════════════════════════════
   CONTACT
════════════════════════════════════════════════ */
.contact-grid { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:start; }
.contact-lead { font-size:1rem; color:var(--text-2); line-height:1.82; margin-bottom:1.75rem; }
.contact-links { display:flex; flex-direction:column; gap:.55rem; }
.contact-link {
  font-family:var(--font-mono); font-size:.76rem;
  color:var(--text-2); text-decoration:none;
  letter-spacing:.1em;
  display:flex; align-items:center; gap:.7rem;
  padding:.68rem .95rem;
  border:1px solid var(--border-lo); border-radius:var(--r);
  background:rgba(14,10,6,.55);
  transition:border-color .25s, color .25s, background .25s;
  position:relative;
}
.contact-link::before {
  content:''; position:absolute; top:-1px; left:-1px;
  width:10px; height:10px;
  border-top:1px solid var(--orange); border-left:1px solid var(--orange);
  opacity:0; transition:opacity .25s;
}
.contact-link:hover { border-color:var(--border-hi); color:var(--orange); background:rgba(180,60,0,.07); }
.contact-link:hover::before { opacity:1; }
.contact-link-icon { width:20px; height:20px; display:flex; align-items:center; justify-content:center; color:var(--orange); flex-shrink:0; }

.magi-panel {
  background:var(--panel); border:1px solid var(--border-lo);
  border-radius:var(--r); padding:1.65rem; position:relative;
  backdrop-filter:blur(8px);
}
.magi-panel::before { content:''; position:absolute; top:-1px; left:-1px; width:14px; height:14px; border-top:1px solid var(--orange); border-left:1px solid var(--orange); }
.magi-panel::after  { content:''; position:absolute; bottom:-1px; right:-1px; width:14px; height:14px; border-bottom:1px solid var(--maroon); border-right:1px solid var(--maroon); }
.magi-panel-head { font-family:var(--font-mono); font-size:.6rem; color:var(--maroon-hi); letter-spacing:.28em; text-transform:uppercase; margin-bottom:1.15rem; padding-bottom:.6rem; border-bottom:1px solid var(--border-lo); }
.magi-status-row { display:flex; align-items:center; justify-content:space-between; padding:.5rem 0; border-bottom:1px solid rgba(180,60,0,.05); font-family:var(--font-mono); font-size:.68rem; }
.magi-status-row:last-child { border-bottom:none; }
.magi-status-key { color:var(--text-3); letter-spacing:.1em; }
.magi-status-val { color:var(--orange); text-shadow:0 0 8px var(--glow); }
.magi-online { display:flex; align-items:center; gap:.4rem; color:#5ad68a; }
.magi-online::before { content:''; width:5px; height:5px; background:#5ad68a; border-radius:50%; box-shadow:0 0 6px rgba(90,214,138,.4); animation:blink 2.2s ease-in-out infinite; flex-shrink:0; }

/* ════════════════════════════════════════════════
   FOOTER
════════════════════════════════════════════════ */
.site-footer {
  position:relative; z-index:2;
  background:rgba(4,3,1,.96);
  border-top:1px solid var(--border-lo);
  padding:1.85rem 2rem 3rem;
}
.footer-inner {
  max-width:1100px; margin:0 auto;
  display:flex; align-items:center; justify-content:space-between;
  flex-wrap:wrap; gap:1rem;
}
.footer-name { font-family:var(--font-mono); font-size:.72rem; color:var(--text-3); letter-spacing:.1em; }
.footer-links { display:flex; gap:1.4rem; }
.footer-links a { font-family:var(--font-mono); font-size:.62rem; color:var(--text-dim); text-decoration:none; letter-spacing:.1em; transition:color .2s; }
.footer-links a:hover { color:var(--orange); }
.footer-meta { font-family:var(--font-mono); font-size:.58rem; color:var(--text-dim); letter-spacing:.08em; }

/* ════════════════════════════════════════════════
   TICKER
════════════════════════════════════════════════ */
.nge-ticker {
  position:fixed; bottom:0; left:0; right:0; z-index:200;
  background:rgba(4,2,0,.97);
  border-top:1px solid var(--maroon);
  height:26px; display:flex; align-items:center; overflow:hidden;
}
.ticker-inner {
  display:inline-block; white-space:nowrap;
  animation:ticker-scroll 36s linear infinite;
  font-family:var(--font-mono); font-size:.58rem;
  color:var(--maroon-hi); letter-spacing:.15em;
  padding-left:100%;
}
@keyframes ticker-scroll { from{transform:translateX(0)} to{transform:translateX(-50%)} }

/* ════════════════════════════════════════════════
   SCROLL REVEAL
════════════════════════════════════════════════ */
.reveal {
  opacity:0; transform:translateY(22px);
  transition:opacity .65s var(--ease), transform .65s var(--ease);
}
.reveal.visible { opacity:1; transform:none; }
.reveal-d1 { transition-delay:.08s; }
.reveal-d2 { transition-delay:.16s; }
.reveal-d3 { transition-delay:.24s; }
.reveal-d4 { transition-delay:.32s; }
.reveal-d5 { transition-delay:.40s; }

/* ════════════════════════════════════════════════
   RESPONSIVE
════════════════════════════════════════════════ */
@media (max-width:768px) {
  .nav-links, .nav-status { display:none; }
  .nav-mobile-toggle { display:flex; }
  .nav-mobile-menu { display:block; }
  .about-grid { grid-template-columns:1fr; }
  .about-avatar-wrap { flex-direction:row; align-items:center; gap:1.25rem; }
  .contact-grid { grid-template-columns:1fr; gap:2.25rem; }
  .section { padding:4.5rem 0; }
  .timeline-header { flex-direction:column; }
  .timeline-meta { text-align:left; }
  .hero-stats { gap:1.5rem; }
}
@media (max-width:480px) {
  .container { padding:0 1.2rem; }
  .projects-grid { grid-template-columns:1fr; }
  .domain-grid { grid-template-columns:1fr; }
  .hero-cta { flex-direction:column; align-items:flex-start; }
}
</style>

<div class="amb" aria-hidden="true"></div>

<!-- ════ BOOT ════ -->
<div id="boot-screen" aria-hidden="true">
  <div class="boot-logo">NERV &middot; MAGI SYSTEM</div>
  <div class="boot-lines">
    <div class="boot-line">INITIALIZING TERMINAL &middot; PORTFOLIO-01</div>
    <div class="boot-line">PATTERN BLUE &mdash; CONFIRMED</div>
    <div class="boot-line">LOADING USER PROFILE</div>
    <div class="boot-line">ALL SYSTEMS GO &middot; AUTHENTICATION COMPLETE</div>
  </div>
  <div class="boot-bar-wrap"><div class="boot-bar"></div></div>
</div>

<!-- ════ NAV ════ -->
<header id="site-nav" role="banner">
  <div class="nav-inner">
    <a href="#hero" class="nav-logo">
      <div class="nav-logo-dot"></div>
      NERV &middot; {{ site.name | split: ' ' | first | upcase }}
    </a>
    <nav aria-label="Main navigation">
      <ul class="nav-links">
        <li><a href="#hero"       class="nav-link active">Home</a></li>
        <li><a href="#about"      class="nav-link">About</a></li>
        <li><a href="#projects"   class="nav-link">Projects</a></li>
        <li><a href="#experience" class="nav-link">Experience</a></li>
        <li><a href="#contact"    class="nav-link">Contact</a></li>
      </ul>
    </nav>
