</header>

<!-- ════ HERO ════ -->
<section id="hero">
  <div class="hero-dataflow" aria-hidden="true">
    <div class="hero-dataflow-inner">
      {% for i in (200..280) %}<div class="data-node">{{ i | prepend: '00' }}</div>{% endfor %}
    </div>
  </div>

  <div class="container">
    <div class="hero-system-id">SYSTEM &middot; PORTFOLIO-01 &middot; USER AUTHENTICATED</div>
    <h1 class="hero-name">{{ site.name }}</h1>
    <p class="hero-role">{{ site.degree }}&nbsp;&nbsp;&middot;&nbsp;&nbsp;{{ site.university }}&nbsp;&nbsp;&middot;&nbsp;&nbsp;{{ site.graduationYear }}</p>
    <p class="hero-bio">{{ site.bio }}</p>
    <div class="hero-cta">
      <a href="#projects"   class="btn btn--primary"><span>View Projects</span></a>
      <a href="#experience" class="btn btn--ghost"><span>Experience</span></a>
      <a href="#about"      class="btn btn--ghost"><span>About Me</span></a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <span class="hero-stat-val">3</span>
        <span class="hero-stat-lbl">Domains</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-val">C/C++</span>
        <span class="hero-stat-lbl">Primary Lang</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-val">{{ site.graduationYear }}</span>
        <span class="hero-stat-lbl">Grad Year</span>
      </div>
    </div>
  </div>
</section>

<div class="nerv-divider" aria-hidden="true"><span class="nerv-divider-label">// UNIT-01 &middot; PROFILE DATA</span></div>

<!-- ════ ABOUT + SKILLS (combined) ════ -->
<section id="about" class="section section--alt">
  <div class="container">

    <!-- Bio -->
    <span class="section-eyebrow reveal">// about</span>
    <h2 class="section-title reveal">About Me</h2>

    <div class="about-grid reveal">
      <div class="about-avatar-wrap">
        <div class="about-avatar" aria-hidden="true">{{ site.name | slice: 0 }}{{ site.name | split: " " | last | slice: 0 }}</div>
        <div class="about-unit-label">UNIT-01</div>
      </div>
      <div>
        <h3 class="about-name">{{ site.name }}</h3>
        <span class="about-subtitle">{{ site.degree }} &middot; {{ site.university }} &middot; {{ site.graduationYear }}</span>
        <p class="about-text">{{ site.bio }}</p>
        <p class="about-text">Most comfortable in C and C++, reaching for Python for tooling and Go for anything network-heavy. Interested in where hardware and software meet &mdash; real-time embedded constraints, low-level rendering pipelines, OS scheduler internals.</p>
        <p class="about-text">Outside of code: system design, CPU microarchitecture, and prototyping game mechanics that probably won't make the final cut.</p>
        <div class="about-cta">
          <a href="mailto:{{ site.email }}" class="btn btn--primary"><span>Get in Touch</span></a>
          <a href="{{ site.github }}"   target="_blank" rel="noopener noreferrer" class="btn btn--ghost"><span>GitHub</span></a>
          <a href="{{ site.linkedin }}" target="_blank" rel="noopener noreferrer" class="btn btn--ghost"><span>LinkedIn</span></a>
        </div>
      </div>
    </div>

    <!-- ── Skills (merged) ── -->
    <div class="skills-section-header reveal">
      <span class="section-eyebrow">// skills &amp; tools</span>
      <h2 class="section-title" style="margin-bottom:1.6rem;">Skills &amp; Technologies</h2>

      <!-- Languages row -->
      <div class="skills-row">
        <span class="skills-row-label">Languages &rarr;</span>
        <div class="chip-row">
          {% for lang in skills.languages %}<span class="chip">{{ lang }}</span>{% endfor %}
        </div>
      </div>

      <!-- Tools row -->
      <div class="skills-row">
        <span class="skills-row-label">Tools &amp; Env &rarr;</span>
        <div class="chip-row">
          {% for tool in skills.tools %}<span class="chip">{{ tool }}</span>{% endfor %}
        </div>
      </div>
    </div>

    <!-- Domain cards -->
    <div class="domain-grid">
      <div class="domain-card reveal reveal-d1">
        <div class="domain-card-bar"></div>
        <span class="domain-badge">CS</span>
        <div class="domain-title">{{ skills.cs.label }}</div>
        <ul class="domain-list">{% for item in skills.cs.items %}<li>{{ item }}</li>{% endfor %}</ul>
      </div>
      <div class="domain-card reveal reveal-d2">
        <div class="domain-card-bar"></div>
        <span class="domain-badge">Game Dev</span>
        <div class="domain-title">{{ skills.gamedev.label }}</div>
        <ul class="domain-list">{% for item in skills.gamedev.items %}<li>{{ item }}</li>{% endfor %}</ul>
      </div>
      <div class="domain-card reveal reveal-d3">
        <div class="domain-card-bar"></div>
        <span class="domain-badge">Embedded</span>
        <div class="domain-title">{{ skills.embedded.label }}</div>
        <ul class="domain-list">{% for item in skills.embedded.items %}<li>{{ item }}</li>{% endfor %}</ul>
      </div>
    </div>

  </div>
</section>

<div class="nerv-divider" aria-hidden="true"><span class="nerv-divider-label">// PROJECTS &middot; CASPAR LOG</span></div>

<!-- ════ PROJECTS ════ -->
<section id="projects" class="section">
  <div class="container">
    <span class="section-eyebrow reveal">// projects</span>
    <h2 class="section-title reveal">Project Log</h2>

    <div class="filter-bar reveal" role="group" aria-label="Filter projects">
      <button class="filter-btn active" data-filter="all">All <span id="count-all"></span></button>
      <button class="filter-btn" data-filter="cs">Computer Science <span id="count-cs"></span></button>
      <button class="filter-btn" data-filter="gamedev">Game Dev <span id="count-gamedev"></span></button>
      <button class="filter-btn" data-filter="embedded">Embedded <span id="count-embedded"></span></button>
    </div>

    <div class="projects-grid" id="projects-grid">
      {% for project in projects %}
      <article class="project-card" data-category="{{ project.category }}">
        <div class="project-card-bar"></div>
        <div class="project-card-top">
          <span class="project-badge">
            {% if project.category == 'cs' %}CS{% elsif project.category == 'gamedev' %}Game Dev{% else %}Embedded{% endif %}
          </span>
          <div style="display:flex;align-items:center;gap:.45rem;">
            {% if project.status == 'in-progress' %}<span class="project-status-active">In Progress</span>{% endif %}
            <span class="project-year">{{ project.year }}</span>
          </div>
        </div>
        <h3 class="project-title">{{ project.title }}</h3>
        <p class="project-desc">{{ project.description }}</p>
        <div class="project-tags">{% for tag in project.tags %}<span class="project-tag">{{ tag }}</span>{% endfor %}</div>
        <div class="project-links">
