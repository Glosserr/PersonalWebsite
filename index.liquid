---
layout: layout.liquid
title: Home
---

<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;600;700;900&display=swap" rel="stylesheet">

<style>
/* ═══════════════════════════════════════════════════════════════
   NEON GENESIS EVANGELION — MAGI TERMINAL THEME
   Home Page — same base as Resume
═══════════════════════════════════════════════════════════════ */

.nge-realm {
  --nge-void:      #030100;
  --nge-dark:      #080200;
  --nge-panel:     rgba(14,4,0,.92);
  --nge-border:    rgba(180,50,0,.30);
  --nge-border2:   rgba(140,0,0,.25);
  --nge-orange:    #e06010;
  --nge-orange2:   #ff7a20;
  --nge-amber:     #c85000;
  --nge-maroon:    #7a1000;
  --nge-red:       #b01010;
  --nge-text:      #f0c090;
  --nge-text2:     #c89060;
  --nge-label:     #e07030;
  --nge-white:     #ffe8c0;
  --nge-glow:      rgba(220,90,0,.35);
  --nge-grid-c:    rgba(180,50,0,.07);
  --nge-font-head: 'Rajdhani', sans-serif;
  --nge-font-orb:  'Orbitron', sans-serif;
  --nge-font-mono: 'Share Tech Mono', monospace;
  --nge-radius:    3px;

  position: relative;
  overflow-x: hidden;
  background: var(--nge-void);
  color: var(--nge-text);
  font-family: var(--nge-font-head);
  min-height: 100vh;
}

/* ── MAGI Grid ── */
.nge-realm::before {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background-image:
    linear-gradient(var(--nge-grid-c) 1px, transparent 1px),
    linear-gradient(90deg, var(--nge-grid-c) 1px, transparent 1px);
  background-size: 42px 42px;
}

/* ── Scan lines ── */
.nge-realm::after {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background: repeating-linear-gradient(
    0deg,
    rgba(0,0,0,.20) 0px,
    rgba(0,0,0,.20) 1px,
    transparent 1px,
    transparent 3px
  );
}

/* ── Ambient glow ── */
.nge-ambient {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background:
    radial-gradient(ellipse 800px 500px at 10% 15%, rgba(140,0,0,.10) 0%,transparent 70%),
    radial-gradient(ellipse 600px 400px at 90% 80%, rgba(200,60,0,.08) 0%,transparent 70%);
}

/* Content z-index */
.nge-realm .nge-hero,
.nge-realm .nge-section { position: relative; z-index: 2; }

/* ════════════
   HERO
════════════ */
.nge-hero {
  min-height: 90vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 6rem 0 4rem;
  position: relative;
  border-bottom: 1px solid var(--nge-border);
}

/* NERV top bar */
.nge-hero::before {
  content: 'NERV · MAGI SYSTEM · TERMINAL ACTIVE · PATTERN BLUE CONFIRMED';
  position: absolute;
  top: 0; left: 0; right: 0;
  font-family: var(--nge-font-mono);
  font-size: .58rem;
  letter-spacing: .3em;
  color: var(--nge-maroon);
  padding: .4rem 1rem;
  background: rgba(8,2,0,.9);
  border-bottom: 1px solid rgba(140,0,0,.2);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.nge-system-id {
  font-family: var(--nge-font-mono);
  color: var(--nge-maroon);
  font-size: .68rem;
  letter-spacing: .3em;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  gap: .75rem;
}
.nge-system-id::before {
  content: '';
  display: inline-block;
  width: 6px; height: 6px;
  background: var(--nge-orange);
  border-radius: var(--nge-radius);
  box-shadow: 0 0 8px var(--nge-glow);
  animation: nge-blink 1.4s step-start infinite;
}
@keyframes nge-blink {
  0%,100% { opacity:1; }
  50%      { opacity:0; }
}

.nge-hero-name {
  font-family: var(--nge-font-orb) !important;
  color: var(--nge-white) !important;
  font-size: clamp(2.8rem, 8vw, 5.5rem);
  font-weight: 900;
  letter-spacing: .06em;
  text-transform: uppercase;
  line-height: 1;
  text-shadow: 0 0 40px var(--nge-glow), 0 0 80px rgba(180,40,0,.15);
  margin: 0 0 .5rem;
}

/* Glitch flicker on name */
@keyframes nge-glitch {
  0%,92%,100% { text-shadow: 0 0 40px var(--nge-glow), 0 0 80px rgba(180,40,0,.15); transform: none; }
  93% { text-shadow: -2px 0 var(--nge-orange), 2px 0 var(--nge-maroon); transform: skewX(-1deg); }
  95% { text-shadow: 2px 0 var(--nge-orange), -2px 0 var(--nge-red); transform: skewX(0.5deg); }
  97% { text-shadow: 0 0 40px var(--nge-glow); transform: none; }
}
.nge-hero-name { animation: nge-glitch 6s ease-in-out infinite; }

.nge-hero-role {
  font-family: var(--nge-font-mono);
  color: var(--nge-orange);
  font-size: clamp(.85rem, 2.5vw, 1.1rem);
  letter-spacing: .2em;
  text-transform: uppercase;
  margin-bottom: 2rem;
  text-shadow: 0 0 10px var(--nge-glow);
}

.nge-hero-bio {
  font-family: var(--nge-font-head);
  color: var(--nge-text);
  font-size: 1.05rem;
  line-height: 1.8;
  max-width: 620px;
  margin-bottom: 2.5rem;
  font-weight: 400;
}

/* ── CTA buttons ── */
.nge-cta-row {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}

.nge-btn {
  font-family: var(--nge-font-mono);
  font-size: .72rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  padding: .75rem 2rem;
  border-radius: var(--nge-radius);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  transition: all .3s ease;
  position: relative;
  overflow: hidden;
}

.nge-btn--primary {
  background: transparent;
  border: 1px solid var(--nge-orange);
  color: var(--nge-orange);
}
.nge-btn--primary::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--nge-orange);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .3s ease;
}
.nge-btn--primary:hover { color: var(--nge-void); box-shadow: 0 0 20px var(--nge-glow); }
.nge-btn--primary:hover::before { transform: scaleX(1); }
.nge-btn--primary span { position: relative; z-index: 1; }

.nge-btn--ghost {
  background: transparent;
  border: 1px solid var(--nge-maroon);
  color: var(--nge-text2);
}
.nge-btn--ghost:hover {
  border-color: var(--nge-orange);
  color: var(--nge-orange);
  box-shadow: 0 0 12px rgba(200,60,0,.15);
}

/* ── Hero stats row ── */
.nge-stats-row {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
}
.nge-stat {
  display: flex;
  flex-direction: column;
  gap: .25rem;
  position: relative;
  padding-left: .75rem;
  border-left: 2px solid var(--nge-maroon);
}
.nge-stat-value {
  font-family: var(--nge-font-orb);
  color: var(--nge-orange);
  font-size: 1.5rem;
  font-weight: 700;
  text-shadow: 0 0 12px var(--nge-glow);
  line-height: 1;
}
.nge-stat-label {
  font-family: var(--nge-font-mono);
  color: var(--nge-maroon);
  font-size: .6rem;
  letter-spacing: .2em;
  text-transform: uppercase;
}

/* ════════════
   DOMAIN PANELS
════════════ */
.nge-section {
  padding: 4rem 0;
}
.nge-section--alt {
  background: rgba(10,3,0,.7);
  border-top: 1px solid var(--nge-border);
  border-bottom: 1px solid var(--nge-border);
}

.nge-section-header {
  margin-bottom: 2.5rem;
}
.nge-section-eyebrow {
  font-family: var(--nge-font-mono);
  color: var(--nge-maroon);
  font-size: .68rem;
  letter-spacing: .35em;
  text-transform: uppercase;
  display: block;
  margin-bottom: .75rem;
}
.nge-section-title {
  font-family: var(--nge-font-head);
  color: var(--nge-white);
  font-size: clamp(1.5rem, 4vw, 2.2rem);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  text-shadow: 0 0 20px var(--nge-glow);
  position: relative;
  display: inline-block;
  margin: 0;
}
.nge-section-title::after {
  content: '';
  position: absolute;
  bottom: -6px; left: 0;
  width: 100%;
  height: 1px;
  background: linear-gradient(90deg, var(--nge-orange), var(--nge-maroon), transparent);
}

/* ── Domain cards grid ── */
.nge-domains {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1.5rem;
}

.nge-domain-card {
  background: var(--nge-panel);
  border: 1px solid var(--nge-border);
  padding: 2rem 1.75rem;
  border-radius: var(--nge-radius);
  position: relative;
  transition: all .35s ease;
  text-decoration: none;
  display: block;
}
.nge-domain-card::before {
  content: '';
  position: absolute;
  top: -1px; left: -1px;
  width: 14px; height: 14px;
  border-top: 2px solid var(--nge-orange);
  border-left: 2px solid var(--nge-orange);
}
.nge-domain-card::after {
  content: '';
  position: absolute;
  bottom: -1px; right: -1px;
  width: 14px; height: 14px;
  border-bottom: 2px solid var(--nge-maroon);
  border-right: 2px solid var(--nge-maroon);
}
.nge-domain-card:hover {
  border-color: var(--nge-orange);
  transform: translateY(-4px);
  box-shadow: 0 0 30px rgba(180,50,0,.15), 0 20px 60px rgba(0,0,0,.4);
}

.nge-domain-icon {
  font-family: var(--nge-font-mono);
  color: var(--nge-orange);
  font-size: 1.8rem;
  margin-bottom: 1rem;
  display: block;
  text-shadow: 0 0 12px var(--nge-glow);
}
.nge-domain-label {
  font-family: var(--nge-font-mono);
  color: var(--nge-maroon);
  font-size: .62rem;
  letter-spacing: .3em;
  text-transform: uppercase;
  margin-bottom: .5rem;
}
.nge-domain-title {
  font-family: var(--nge-font-head);
  color: var(--nge-white);
  font-size: 1.2rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
  margin-bottom: .75rem;
}
.nge-domain-desc {
  font-family: var(--nge-font-head);
  color: var(--nge-text2);
  font-size: .9rem;
  line-height: 1.65;
  font-weight: 400;
}

/* ── Featured skills bar ── */
.nge-skills-bar {
  display: flex;
  flex-wrap: wrap;
  gap: .5rem;
  margin-top: 2rem;
}
.nge-skill-chip {
  font-family: var(--nge-font-mono);
  font-size: .68rem;
  background: rgba(160,40,0,.18);
  border: 1px solid rgba(200,60,0,.25);
  color: var(--nge-text);
  padding: .28rem .85rem;
  border-radius: var(--nge-radius);
  letter-spacing: .05em;
  transition: all .25s;
}
.nge-skill-chip:hover {
  background: rgba(200,60,0,.28);
  border-color: var(--nge-orange);
  box-shadow: 0 0 10px var(--nge-glow);
}

/* ── MAGI ticker ── */
.nge-ticker {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  z-index: 100;
  background: rgba(4,1,0,.95);
  border-top: 1px solid var(--nge-maroon);
  overflow: hidden;
  height: 24px;
  display: flex;
  align-items: center;
}
.nge-ticker-inner {
  display: inline-block;
  white-space: nowrap;
  animation: nge-scroll 28s linear infinite;
  font-family: var(--nge-font-mono);
  font-size: .62rem;
  color: var(--nge-maroon);
  letter-spacing: .12em;
  padding-left: 100%;
}
@keyframes nge-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

/* ── Body padding for ticker ── */
body { padding-bottom: 24px; }
</style>

<div class="nge-realm">
  <div class="nge-ambient" aria-hidden="true"></div>

  <!-- ══════════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════════ -->
  <div class="nge-hero">
    <div class="container">

      <div class="nge-system-id">SYSTEM · PORTFOLIO-01 · USER AUTHENTICATED</div>

      <h1 class="nge-hero-name">{{ site.name }}</h1>
      <p class="nge-hero-role">{{ site.degree }} &nbsp;·&nbsp; {{ site.university }} &nbsp;·&nbsp; {{ site.graduationYear }}</p>
      <p class="nge-hero-bio">{{ site.bio }}</p>

      <div class="nge-cta-row">
        <a href="/projects/" class="nge-btn nge-btn--primary"><span>View Projects</span></a>
        <a href="/resume/"   class="nge-btn nge-btn--ghost">Resume &amp; Experience</a>
        <a href="/about/"    class="nge-btn nge-btn--ghost">About Me</a>
      </div>

      <div class="nge-stats-row">
        <div class="nge-stat">
          <span class="nge-stat-value">3</span>
          <span class="nge-stat-label">Domains</span>
        </div>
        <div class="nge-stat">
          <span class="nge-stat-value">C/C++</span>
          <span class="nge-stat-label">Primary Lang</span>
        </div>
        <div class="nge-stat">
          <span class="nge-stat-value">{{ site.graduationYear }}</span>
          <span class="nge-stat-label">Grad Year</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════
       DOMAIN PANELS
  ══════════════════════════════════════════════════ -->
  <section class="nge-section nge-section--alt">
    <div class="container">
      <div class="nge-section-header">
        <span class="nge-section-eyebrow">// active systems</span>
        <h2 class="nge-section-title">Areas of Focus</h2>
      </div>

      <div class="nge-domains">
        <a href="/projects/?filter=cs" class="nge-domain-card" style="text-decoration:none">
          <span class="nge-domain-icon">[CS]</span>
          <div class="nge-domain-label">01 · Computer Science</div>
          <div class="nge-domain-title">Systems &amp; Software</div>
          <p class="nge-domain-desc">Operating systems, data structures, algorithms, networks, and low-level systems programming in C and C++.</p>
        </a>

        <a href="/projects/?filter=gamedev" class="nge-domain-card" style="text-decoration:none">
          <span class="nge-domain-icon">[GD]</span>
          <div class="nge-domain-label">02 · Game Development</div>
          <div class="nge-domain-title">Worlds &amp; Mechanics</div>
          <p class="nge-domain-desc">Game engines, rendering pipelines, physics systems, and the craft of interactive experience design.</p>
        </a>

        <a href="/projects/?filter=embedded" class="nge-domain-card" style="text-decoration:none">
          <span class="nge-domain-icon">[HW]</span>
          <div class="nge-domain-label">03 · Embedded Systems</div>
          <div class="nge-domain-title">Hardware &amp; Realtime</div>
          <p class="nge-domain-desc">Microcontrollers, real-time operating systems, hardware/software interfaces, and bare-metal firmware.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════
       SKILLS SNAPSHOT
  ══════════════════════════════════════════════════ -->
  <section class="nge-section">
    <div class="container">
      <div class="nge-section-header">
        <span class="nge-section-eyebrow">// loadout</span>
        <h2 class="nge-section-title">Core Skills</h2>
      </div>

      <div class="nge-skills-bar">
        {% for lang in skills.languages %}
        <span class="nge-skill-chip">{{ lang }}</span>
        {% endfor %}
        {% for item in skills.cs.items %}
        <span class="nge-skill-chip">{{ item }}</span>
        {% endfor %}
        {% for item in skills.embedded.items %}
        <span class="nge-skill-chip">{{ item }}</span>
        {% endfor %}
        {% for tool in skills.tools %}
        <span class="nge-skill-chip">{{ tool }}</span>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════
       CONTACT / LINKS
  ══════════════════════════════════════════════════ -->
  <section class="nge-section nge-section--alt">
    <div class="container">
      <div class="nge-section-header">
        <span class="nge-section-eyebrow">// contact</span>
        <h2 class="nge-section-title">Get in Touch</h2>
      </div>
      <div class="nge-cta-row">
        <a href="mailto:{{ site.email }}"   class="nge-btn nge-btn--primary"><span>Email Me</span></a>
        <a href="{{ site.github }}"          class="nge-btn nge-btn--ghost" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="{{ site.linkedin }}"        class="nge-btn nge-btn--ghost" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </div>
  </section>

</div>

<!-- MAGI Status Ticker -->
<div class="nge-ticker" aria-hidden="true">
  <div class="nge-ticker-inner">
    MAGI-01: CASPAR — ONLINE &nbsp;·&nbsp; MAGI-02: BALTHASAR — ONLINE &nbsp;·&nbsp; MAGI-03: MELCHIOR — ONLINE &nbsp;·&nbsp; SYSTEM STATUS: NOMINAL &nbsp;·&nbsp; PATTERN BLUE — CONFIRMED &nbsp;·&nbsp; ALL SYSTEMS GO &nbsp;·&nbsp; NERV HQ — TERMINAL ACTIVE &nbsp;·&nbsp;
    MAGI-01: CASPAR — ONLINE &nbsp;·&nbsp; MAGI-02: BALTHASAR — ONLINE &nbsp;·&nbsp; MAGI-03: MELCHIOR — ONLINE &nbsp;·&nbsp; SYSTEM STATUS: NOMINAL &nbsp;·&nbsp; PATTERN BLUE — CONFIRMED &nbsp;·&nbsp; ALL SYSTEMS GO &nbsp;·&nbsp; NERV HQ — TERMINAL ACTIVE &nbsp;·&nbsp;
  </div>
</div>
