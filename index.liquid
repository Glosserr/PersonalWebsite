<script>
(function () {
  var nav        = document.getElementById('site-nav');
  var navLinks   = document.querySelectorAll('header .nav-link');
  var sectionIds = ['hero','about','projects','experience','contact'];
  var reveals    = document.querySelectorAll('.reveal');
  var dataflow   = document.querySelector('.hero-dataflow');

  /* ── Reveal on scroll ── */
  function revealElements() {
    var vh = window.innerHeight;
    reveals.forEach(function(el) {
      if (el.getBoundingClientRect().top < vh - 55) el.classList.add('visible');
    });
  }

  /* ── Active nav highlight ── */
  function updateNav() {
    var y = window.scrollY + 80;
    var active = 'hero';
    sectionIds.forEach(function(id) {
      var s = document.getElementById(id);
      if (s && s.offsetTop <= y) active = id;
    });
    navLinks.forEach(function(l) {
      l.classList.toggle('active', l.getAttribute('href') === '#' + active);
    });
  }

  /* ── Scroll handler ── */
  window.addEventListener('scroll', function () {
    nav.classList.toggle('scrolled', window.scrollY > 30);
    updateNav();
    revealElements();
    if (dataflow) dataflow.style.transform = 'translateY(' + (window.scrollY * 0.18) + 'px)';
  }, { passive: true });

  /* Run on load */
  nav.classList.toggle('scrolled', window.scrollY > 30);
  updateNav();
  revealElements();

  /* ── Mobile toggle ── */
  var toggle     = document.querySelector('.nav-mobile-toggle');
  var mobileMenu = document.querySelector('.nav-mobile-menu');
  if (toggle) {
    toggle.addEventListener('click', function () {
      var open = toggle.classList.toggle('open');
      mobileMenu.classList.toggle('open', open);
      toggle.setAttribute('aria-expanded', String(open));
    });
    mobileMenu.querySelectorAll('.nav-link').forEach(function (l) {
      l.addEventListener('click', function () {
        toggle.classList.remove('open');
        mobileMenu.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }

  /* ── Project filter ── */
  var grid = document.getElementById('projects-grid');
  if (grid) {
    var cards      = Array.from(grid.querySelectorAll('.project-card'));
    var filterBtns = document.querySelectorAll('.filter-btn');
    var counts     = { all: cards.length, cs: 0, gamedev: 0, embedded: 0 };
    cards.forEach(function(c) { if (counts[c.dataset.category] !== undefined) counts[c.dataset.category]++; });
    Object.keys(counts).forEach(function(k) {
      var el = document.getElementById('count-' + k);
      if (el) el.textContent = '(' + counts[k] + ')';
    });
    filterBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        filterBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        var f = btn.dataset.filter;
        cards.forEach(function (card) {
          var show = f === 'all' || card.dataset.category === f;
          card.style.display = show ? '' : 'none';
          if (show) { card.style.animation = 'none'; void card.offsetHeight; card.style.animation = ''; }
        });
      });
    });
  }

  /* ── Smooth anchor scroll ── */
  document.querySelectorAll('a[href^="#"]').forEach(function (a) {
    a.addEventListener('click', function (e) {
      var t = document.querySelector(a.getAttribute('href'));
      if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth' }); }
    });
  });

}());
</script>
