---
layout: layout.liquid
title: Resume
---

<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;600;700&display=swap" rel="stylesheet">

<style>
/* ═══════════════════════════════════════════════════════════════
   NEON GENESIS EVANGELION — MAGI TERMINAL THEME
   Resume & Home shared style
   Gritty oranges · Hard maroons · Dark reds · NERV grid UI
═══════════════════════════════════════════════════════════════ */

.nge-realm {
  --nge-void:      #030100;
  --nge-dark:      #080200;
  --nge-panel:     rgba(14,4,0,.92);
  --nge-border:    rgba(180,50,0,.30);
  --nge-border2:   rgba(140,0,0,.25);
  --nge-orange:    #e06010;
  --nge-orange2:   #ff7a20;
  --nge-amber:     #c85000;
  --nge-maroon:    #7a1000;
  --nge-red:       #b01010;
  --nge-crimson:   #8b0000;
  --nge-text:      #f0c090;
  --nge-text2:     #c89060;
  --nge-label:     #e07030;
  --nge-white:     #ffe8c0;
  --nge-glow:      rgba(220,90,0,.35);
  --nge-grid-c:    rgba(180,50,0,.07);
  --nge-font-head: 'Rajdhani', sans-serif;
  --nge-font-mono: 'Share Tech Mono', monospace;
  --nge-radius:    3px;

  position: relative;
  overflow-x: hidden;
  background: var(--nge-void);
  color: var(--nge-text);
  font-family: var(--nge-font-head);
  min-height: 100vh;
}

/* ── MAGI Grid overlay ── */
.nge-realm::before {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background-image:
    linear-gradient(var(--nge-grid-c) 1px, transparent 1px),
    linear-gradient(90deg, var(--nge-grid-c) 1px, transparent 1px);
  background-size: 42px 42px;
}

/* ── CRT scan lines ── */
.nge-realm::after {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background: repeating-linear-gradient(
    0deg,
    rgba(0,0,0,.20) 0px,
    rgba(0,0,0,.20) 1px,
    transparent 1px,
    transparent 3px
  );
}

/* ── Ambient red glow ── */
.nge-ambient {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background:
    radial-gradient(ellipse 700px 500px at 15% 20%, rgba(140,0,0,.12) 0%,transparent 70%),
    radial-gradient(ellipse 600px 400px at 85% 75%, rgba(200,60,0,.10) 0%,transparent 70%),
    radial-gradient(ellipse 400px 300px at 50% 50%, rgba(80,0,0,.08) 0%,transparent 70%);
}

/* ── Content z-index ── */
.nge-realm .page-hero,
.nge-realm .section { position: relative; z-index: 2; }

/* ── Corner bracket decoration ── */
.nge-corner {
  position: absolute;
  width: 18px; height: 18px;
  pointer-events: none;
}
.nge-corner--tl { top:0;    left:0;  border-top: 2px solid var(--nge-orange); border-left:  2px solid var(--nge-orange); }
.nge-corner--tr { top:0;    right:0; border-top: 2px solid var(--nge-orange); border-right: 2px solid var(--nge-orange); }
.nge-corner--bl { bottom:0; left:0;  border-bottom: 2px solid var(--nge-orange); border-left:  2px solid var(--nge-orange); }
.nge-corner--br { bottom:0; right:0; border-bottom: 2px solid var(--nge-orange); border-right: 2px solid var(--nge-orange); }

/* ════════════
   HERO
════════════ */
.nge-realm .page-hero {
  background: transparent !important;
  padding: 4.5rem 0 2.5rem;
  border-bottom: 1px solid var(--nge-border);
  position: relative;
}

/* Top status bar */
.nge-realm .page-hero::before {
  content: 'NERV · MAGI SYSTEM · TERMINAL ACTIVE';
  position: absolute;
  top: 0; left: 0; right: 0;
  font-family: var(--nge-font-mono);
  font-size: .6rem;
  letter-spacing: .35em;
  color: var(--nge-maroon);
  padding: .4rem 1rem;
  border-bottom: 1px solid rgba(140,0,0,.2);
  background: rgba(10,2,0,.8);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.nge-realm .section-label {
  font-family: var(--nge-font-mono) !important;
  color: var(--nge-label) !important;
  font-size: .72rem !important;
  letter-spacing: .35em !important;
  display: block;
  margin-bottom: .75rem;
  text-shadow: 0 0 8px var(--nge-glow);
}

.nge-realm .page-title,
.nge-realm h1 {
  font-family: var(--nge-font-head) !important;
  color: var(--nge-white) !important;
  font-size: clamp(2rem, 5.5vw, 3.5rem) !important;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  text-shadow: 0 0 30px var(--nge-glow), 0 0 60px rgba(180,40,0,.15);
  margin: 0;
}

/* Download row */
.nge-realm .resume-download-row {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
  margin-top: 1.25rem;
}

.nge-realm .resume-hint {
  font-family: var(--nge-font-mono) !important;
  font-size: .72rem !important;
  color: var(--nge-maroon) !important;
  letter-spacing: .05em;
}

/* ════════════
   SECTIONS
════════════ */
.nge-realm .section {
  background: transparent !important;
  padding: 4rem 0;
}

.nge-realm .section--alt {
  background: rgba(10,3,0,.7) !important;
  border-top:    1px solid var(--nge-border);
  border-bottom: 1px solid var(--nge-border);
  backdrop-filter: blur(6px);
}

/* ════════════
   SECTION HEADER
════════════ */
.nge-realm .section-header { margin-bottom: 2.5rem; }

.nge-realm .section-title {
  font-family: var(--nge-font-head) !important;
  color: var(--nge-white) !important;
  font-size: clamp(1.4rem, 3.5vw, 2rem) !important;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .1em;
  text-shadow: 0 0 20px var(--nge-glow);
  position: relative;
  display: inline-block;
}
.nge-realm .section-title::after {
  content: '';
  position: absolute;
  bottom: -6px; left: 0;
  width: 100%;
  height: 1px;
  background: linear-gradient(90deg, var(--nge-orange), var(--nge-maroon), transparent);
  box-shadow: 0 0 6px var(--nge-glow);
}

/* ════════════
   BUTTONS
════════════ */
.nge-realm .btn--primary,
.nge-realm .btn--download {
  background: transparent !important;
  border: 1px solid var(--nge-orange) !important;
  color: var(--nge-orange) !important;
  font-family: var(--nge-font-mono) !important;
  font-size: .72rem !important;
  letter-spacing: .15em;
  text-transform: uppercase;
  padding: .65rem 1.75rem !important;
  border-radius: var(--nge-radius) !important;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  position: relative;
  overflow: hidden;
  transition: all .3s ease;
  box-shadow: inset 0 0 0 0 var(--nge-orange);
}
.nge-realm .btn--primary::before,
.nge-realm .btn--download::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--nge-orange);
  opacity: 0;
  transition: opacity .3s;
}
.nge-realm .btn--primary:hover,
.nge-realm .btn--download:hover {
  color: var(--nge-void) !important;
  box-shadow: 0 0 20px var(--nge-glow) !important;
}
.nge-realm .btn--primary:hover::before,
.nge-realm .btn--download:hover::before { opacity: 1; }
.nge-realm .btn--primary span,
.nge-realm .btn--download span,
.nge-realm .btn--primary svg,
.nge-realm .btn--download svg { position: relative; z-index: 1; }

/* ════════════
   TIMELINE
════════════ */
.nge-realm .timeline {
  position: relative;
  padding-left: 2rem;
}

.nge-realm .timeline-item {
  position: relative;
  margin-bottom: 2.5rem;
  display: flex;
  gap: 1.5rem;
}

.nge-realm .timeline-marker {
  position: absolute;
  left: -2rem;
  top: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nge-realm .timeline-dot {
  width: 10px;
  height: 10px;
  background: var(--nge-orange);
  box-shadow: 0 0 10px var(--nge-glow), 0 0 20px rgba(220,90,0,.2);
  border-radius: var(--nge-radius);
  flex-shrink: 0;
  margin-top: 5px;
  position: relative;
}
.nge-realm .timeline-dot::after {
  content: '';
  position: absolute;
  inset: -3px;
  border: 1px solid rgba(220,90,0,.3);
  border-radius: var(--nge-radius);
  animation: nge-dot-pulse 2.5s ease-in-out infinite;
}
@keyframes nge-dot-pulse {
  0%,100% { opacity:1; transform:scale(1); }
  50%      { opacity:0; transform:scale(1.5); }
}

.nge-realm .timeline-line {
  width: 1px;
  flex-grow: 1;
  background: linear-gradient(var(--nge-maroon), transparent);
  min-height: 40px;
  margin-top: 4px;
}

.nge-realm .timeline-body {
  flex-grow: 1;
  background: var(--nge-panel);
  border: 1px solid var(--nge-border);
  padding: 1.4rem 1.6rem;
  border-radius: var(--nge-radius);
  position: relative;
  transition: all .3s ease;
}
.nge-realm .timeline-body:hover {
  border-color: var(--nge-orange);
  box-shadow: 0 0 20px rgba(200,60,0,.1), inset 0 0 30px rgba(200,60,0,.03);
}

/* MAGI panel corner brackets */
.nge-realm .timeline-body::before {
  content: '';
  position: absolute;
  top: -1px; left: -1px;
  width: 12px; height: 12px;
  border-top: 2px solid var(--nge-orange);
  border-left: 2px solid var(--nge-orange);
  border-radius: 0;
}
.nge-realm .timeline-body::after {
  content: '';
  position: absolute;
  bottom: -1px; right: -1px;
  width: 12px; height: 12px;
  border-bottom: 2px solid var(--nge-maroon);
  border-right: 2px solid var(--nge-maroon);
}

.nge-realm .timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: .75rem;
}

.nge-realm .timeline-role {
  font-family: var(--nge-font-head) !important;
  color: var(--nge-white) !important;
  font-size: 1.1rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
  margin: 0;
}

.nge-realm .timeline-company {
  font-family: var(--nge-font-mono) !important;
  color: var(--nge-orange) !important;
  font-size: .82rem;
  margin: .2rem 0 0;
  letter-spacing: .08em;
}

.nge-realm .timeline-dates,
.nge-realm .timeline-location {
  font-family: var(--nge-font-mono) !important;
  font-size: .7rem;
  color: var(--nge-text2) !important;
  letter-spacing: .08em;
  display: block;
}

.nge-realm .timeline-current {
  color: var(--nge-orange);
  text-shadow: 0 0 6px var(--nge-glow);
}

.nge-realm .timeline-meta {
  text-align: right;
  flex-shrink: 0;
}

.nge-realm .timeline-desc {
  font-family: var(--nge-font-head) !important;
  color: var(--nge-text) !important;
  font-size: .92rem;
  line-height: 1.7;
  font-weight: 400;
  margin: 0;
}

.nge-realm .timeline-tags {
  display: flex;
  flex-wrap: wrap;
  gap: .4rem;
  margin-top: .75rem;
}

.nge-realm .timeline-item--work .timeline-dot { background: var(--nge-orange); }
.nge-realm .timeline-item--education .timeline-dot { background: var(--nge-maroon); }

/* ════════════
   SKILLS GRID
════════════ */
.nge-realm .resume-skills-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1.25rem;
}

.nge-realm .resume-skill-block {
  background: var(--nge-panel);
  border: 1px solid var(--nge-border);
  padding: 1.25rem 1.4rem;
  border-radius: var(--nge-radius);
  position: relative;
  transition: all .3s ease;
}
.nge-realm .resume-skill-block::before {
  content: '';
  position: absolute;
  top: -1px; left: -1px;
  width: 10px; height: 10px;
  border-top: 1px solid var(--nge-orange);
  border-left: 1px solid var(--nge-orange);
}
.nge-realm .resume-skill-block:hover {
  border-color: var(--nge-amber);
  box-shadow: 0 0 16px rgba(200,60,0,.1);
}

.nge-realm .resume-skill-heading {
  font-family: var(--nge-font-mono) !important;
  color: var(--nge-label) !important;
  font-size: .7rem !important;
  letter-spacing: .2em;
  text-transform: uppercase;
  margin-bottom: .85rem;
}

/* ── Chips ── */
.nge-realm .lang-chip {
  background: rgba(160,40,0,.18) !important;
  border: 1px solid rgba(200,60,0,.25) !important;
  color: var(--nge-text) !important;
  border-radius: var(--nge-radius) !important;
  font-family: var(--nge-font-mono) !important;
  font-size: .72rem !important;
  padding: .28rem .8rem !important;
  transition: all .25s ease;
}
.nge-realm .lang-chip:hover {
  background: rgba(200,60,0,.28) !important;
  border-color: var(--nge-orange) !important;
  box-shadow: 0 0 10px var(--nge-glow);
}

.nge-realm .lang-chip--cs       { border-color: rgba(74,144,212,.3) !important; color: #90c0e8 !important; }
.nge-realm .lang-chip--gamedev  { border-color: rgba(0,200,255,.25) !important; color: #80d8f0 !important; }
.nge-realm .lang-chip--embedded { border-color: rgba(200,60,0,.35) !important;  color: var(--nge-orange) !important; }
.nge-realm .lang-chip--tool     { border-color: rgba(160,60,0,.25) !important;  color: var(--nge-text2) !important; }

/* ── Tags (timeline) ── */
.nge-realm .project-tag {
  font-family: var(--nge-font-mono) !important;
  background: rgba(160,40,0,.15);
  color: var(--nge-text2);
  border: 1px solid rgba(200,60,0,.2);
  font-size: .68rem;
  padding: .2rem .7rem;
  border-radius: var(--nge-radius);
  letter-spacing: .05em;
}

/* ── Resume download footer ── */
.nge-realm .resume-download-footer {
  margin-top: 3rem;
  text-align: center;
}

/* ── MAGI status ticker ── */
.nge-ticker {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  z-index: 100;
  background: rgba(4,1,0,.95);
  border-top: 1px solid var(--nge-maroon);
  overflow: hidden;
  height: 24px;
  display: flex;
  align-items: center;
}
.nge-ticker-inner {
  display: inline-block;
  white-space: nowrap;
  animation: nge-scroll 28s linear infinite;
  font-family: var(--nge-font-mono);
  font-size: .62rem;
  color: var(--nge-maroon);
  letter-spacing: .12em;
  padding-left: 100%;
}
@keyframes nge-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
</style>

<div class="nge-realm">
  <div class="nge-ambient" aria-hidden="true"></div>

  <!-- ══════════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════════ -->
  <div class="page-hero page-hero--resume">
    <div class="container">
      <span class="section-label mono">// resume</span>
      <h1 class="page-title">Resume &amp; Experience</h1>
      <div class="resume-download-row">
        <a href="{{ site.resumeFile }}" class="btn btn--primary btn--download" download>
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <span>Download PDF Resume</span>
        </a>
        <span class="resume-hint mono">Place your PDF at <code style="font-family:inherit;background:rgba(200,60,0,.12);padding:.1rem .4rem;border:1px solid rgba(200,60,0,.2)">public/resume.pdf</code></span>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════
       EXPERIENCE TIMELINE
  ══════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label mono">experience &amp; education</span>
        <h2 class="section-title">Background</h2>
      </div>

      <div class="timeline">
        {% for item in experience %}
        <div class="timeline-item timeline-item--{{ item.type }}">
          <div class="timeline-marker">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-body">
            <div class="timeline-header">
              <div class="timeline-title-group">
                <h3 class="timeline-role">{{ item.title }}</h3>
                <p class="timeline-company">{{ item.company }}</p>
              </div>
              <div class="timeline-meta">
                <span class="timeline-dates mono">{{ item.startDate }} — {% if item.current %}<span class="timeline-current">Present</span>{% else %}{{ item.endDate }}{% endif %}</span>
                <span class="timeline-location mono">{{ item.location }}</span>
              </div>
            </div>
            <p class="timeline-desc">{{ item.description }}</p>
            {% if item.technologies.size > 0 %}
            <div class="timeline-tags">
              {% for tech in item.technologies %}
              <span class="project-tag">{{ tech }}</span>
              {% endfor %}
            </div>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════
       SKILLS
  ══════════════════════════════════════════════════ -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-label mono">skills at a glance</span>
        <h2 class="section-title">Technical Skills</h2>
      </div>

      <div class="resume-skills-grid">
        <div class="resume-skill-block">
          <h3 class="resume-skill-heading mono">Languages</h3>
          <div class="skills-language-chips" style="display:flex;flex-wrap:wrap;gap:.4rem;">
            {% for lang in skills.languages %}
            <span class="lang-chip">{{ lang }}</span>
            {% endfor %}
          </div>
        </div>
        <div class="resume-skill-block">
          <h3 class="resume-skill-heading mono">CS &amp; Software</h3>
          <div class="skills-language-chips" style="display:flex;flex-wrap:wrap;gap:.4rem;">
            {% for item in skills.cs.items %}
            <span class="lang-chip lang-chip--cs">{{ item }}</span>
            {% endfor %}
          </div>
        </div>
        <div class="resume-skill-block">
          <h3 class="resume-skill-heading mono">Game Development</h3>
          <div class="skills-language-chips" style="display:flex;flex-wrap:wrap;gap:.4rem;">
            {% for item in skills.gamedev.items %}
            <span class="lang-chip lang-chip--gamedev">{{ item }}</span>
            {% endfor %}
          </div>
        </div>
        <div class="resume-skill-block">
          <h3 class="resume-skill-heading mono">Embedded Systems</h3>
          <div class="skills-language-chips" style="display:flex;flex-wrap:wrap;gap:.4rem;">
            {% for item in skills.embedded.items %}
            <span class="lang-chip lang-chip--embedded">{{ item }}</span>
            {% endfor %}
          </div>
        </div>
        <div class="resume-skill-block">
          <h3 class="resume-skill-heading mono">Tools &amp; Environment</h3>
          <div class="skills-language-chips" style="display:flex;flex-wrap:wrap;gap:.4rem;">
            {% for tool in skills.tools %}
            <span class="lang-chip lang-chip--tool">{{ tool }}</span>
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="resume-download-footer">
        <a href="{{ site.resumeFile }}" class="btn btn--primary btn--download" download>
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <span>Download Full Resume (PDF)</span>
        </a>
      </div>
    </div>
  </section>

</div>

<!-- MAGI Status Ticker -->
<div class="nge-ticker" aria-hidden="true">
  <div class="nge-ticker-inner">
    MAGI-01: CASPAR — ONLINE &nbsp;·&nbsp; MAGI-02: BALTHASAR — ONLINE &nbsp;·&nbsp; MAGI-03: MELCHIOR — ONLINE &nbsp;·&nbsp; SYSTEM STATUS: NOMINAL &nbsp;·&nbsp; PATTERN BLUE — CONFIRMED &nbsp;·&nbsp; ALL SYSTEMS OPERATIONAL &nbsp;·&nbsp; NERV HQ — TERMINAL ACTIVE &nbsp;·&nbsp;
    MAGI-01: CASPAR — ONLINE &nbsp;·&nbsp; MAGI-02: BALTHASAR — ONLINE &nbsp;·&nbsp; MAGI-03: MELCHIOR — ONLINE &nbsp;·&nbsp; SYSTEM STATUS: NOMINAL &nbsp;·&nbsp; PATTERN BLUE — CONFIRMED &nbsp;·&nbsp; ALL SYSTEMS OPERATIONAL &nbsp;·&nbsp; NERV HQ — TERMINAL ACTIVE &nbsp;·&nbsp;
  </div>
</div>
